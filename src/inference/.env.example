# 0Gora 0G compute service — copy to .env (gitignored). Never commit real values.
PORT=8090
ZEROG_RPC_URL=https://evmrpc.0g.ai
# Real 0G wire model id (org-prefixed; confirm via `npm run probe`). e.g. zai-org/GLM-5-FP8
ZEROG_MODEL=zai-org/GLM-5-FP8
# Dev: ZEROG_MOCK=true returns canned answers (no funds). false = real 0G inference.
ZEROG_MOCK=false
# Funded 0G mainnet private key — injected from a secrets manager at runtime. DO NOT commit.
ZEROG_PRIVATE_KEY=
