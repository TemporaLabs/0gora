  ],
  "homepage": "https://0gora.temporalabs.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TemporaLabs/0gora.git",
    "directory": "src/mcp"
  },
  "bugs": {
    "url": "https://github.com/TemporaLabs/0gora/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  }
}
