{
  "name": "0gora-mcp",
  "version": "0.2.0",
  "description": "MCP server for 0Gora — connect any AI agent to a verifiable, TEE-attested 0G knowledge agora (ask / search / list models)",
  "type": "module",
  "bin": {
    "0gora-mcp": "server/stdio.js"
  },
  "files": [
    "server/",
    "client/",
    "README.md"
  ],
  "scripts": {
    "start": "node server/stdio.js",
    "start:http": "node server/http.js",
    "test": "node test/smoke.mjs",
    "client:example": "node client/example.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "0g",
    "0gora",
    "rag",
    "ai-agents",
