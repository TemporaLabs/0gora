# ── Co-hosted 0Gora (0G + ERC-8226) — runtime + secrets ──────────────────────
# Copy to `.env` (gitignored, NEVER committed) and fill in. This ONE env file is
# shared by both agoras: they run on the SAME 0G inference sidecar, so there is a
# single wallet, a single model allowlist, and a single contribute key. What differs
# between the agoras (branding, corpus, collection) is declarative and lives in each
# examples/<id>/0gora.config.json — not here.
#
#   cp examples/multi/.env.example examples/multi/.env   &&   $EDITOR examples/multi/.env

# 0G wallet that pays for verifiable inference for BOTH agoras. KEEP THIS SECRET.
# One funded mainnet key. (Co-hosting on one sidecar is exactly why a single shared
# key is safe here — one process, calls serialized, no cross-instance nonce races.)
ZEROG_PRIVATE_KEY=

# Production MUST be false. (docker-compose.prod.yml also hard-pins this to false.)
ZEROG_MOCK=false

# 0G mainnet RPC.
ZEROG_RPC_URL=https://evmrpc.0g.ai

# Default model + the allowlist shown in the picker — shared across both agoras.
ZEROG_MODEL=zai-org/GLM-5-FP8
ZEROG_MODELS=0gm,zai-org/GLM-5.1-FP8,deepseek-v4-pro,qwen3.7-max

# Corpus-relevance gate (shared).
RELEVANCE_THRESHOLD=0.70

# Opens /contribute for seeding BOTH agoras (each seed.sh tags its own instance).
CONTRIBUTE_KEY=
