# ── The ERC-8226 0Gora — runtime + secrets ───────────────────────────────────
# Copy this file to `.env` (gitignored, NEVER committed) and fill in the real
# values. Secrets live ONLY here — declarative instance config (branding, corpus,
# prompts) lives in 0gora.config.json, which is committed and secret-free.
#
#   cp .env.example .env   &&   $EDITOR .env
#
# Running ERC-8226 STANDALONE (this folder's compose.override.yml)? Fill this in.
# Co-hosting it WITH the 0G agora (the production layout)? You don't use this file —
# the shared wallet + toggles live in ../multi/.env instead. See ../multi/README.md.

# 0G wallet that pays for verifiable inference. KEEP THIS SECRET. A funded mainnet
# key. Leave blank and set ZEROG_MOCK=true to run locally without funds.
ZEROG_PRIVATE_KEY=

# true  → no 0G calls; answers are placeholders (no funds needed).
# false → real, TEE-verified inference on 0G mainnet (requires a funded key above).
ZEROG_MOCK=true

# 0G mainnet RPC.
ZEROG_RPC_URL=https://evmrpc.0g.ai

# Default model + the allowlist shown in the picker (comma-separated). Same roster
# as the 0G agora — both run on the one funded wallet.
ZEROG_MODEL=zai-org/GLM-5-FP8
ZEROG_MODELS=0gm,zai-org/GLM-5.1-FP8,deepseek-v4-pro,qwen3.7-max

# Top vector-cosine below which the corpus is treated as having nothing relevant
# (the model then answers from general knowledge instead of refusing).
RELEVANCE_THRESHOLD=0.70

# Set to a secret to open the /contribute ingestion endpoint (seed.sh uses it).
# Leave blank to keep contribution closed.
CONTRIBUTE_KEY=
