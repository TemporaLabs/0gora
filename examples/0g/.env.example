# ── The 0G 0Gora — runtime + secrets ─────────────────────────────────────────
# Copy this file to `.env` (which is gitignored and NEVER committed) and fill in
# the real values. Secrets live ONLY here — declarative instance config (branding,
# corpus, prompts) lives in 0gora.config.json, which is committed and secret-free.
#
#   cp .env.example .env   &&   $EDITOR .env

# 0G wallet that pays for verifiable inference. KEEP THIS SECRET. A funded mainnet
# key. Leave blank and set ZEROG_MOCK=true to run locally without funds.
ZEROG_PRIVATE_KEY=

# true  → no 0G calls; the picker is populated and answers are placeholders (no funds needed).
# false → real, TEE-verified inference on 0G mainnet (requires a funded key above).
ZEROG_MOCK=true

# 0G mainnet RPC.
ZEROG_RPC_URL=https://evmrpc.0g.ai

# Default model + the allowlist shown in the picker (comma-separated). Only models
# registered on the direct serving broker WITH TEE attestation AND a funded provider
# should be listed — otherwise the picker offers a model that 502s. Empty = offer all.
ZEROG_MODEL=zai-org/GLM-5-FP8
ZEROG_MODELS=0gm,zai-org/GLM-5.1-FP8,deepseek-v4-pro,qwen3.7-max

# Top vector-cosine below which the corpus is treated as having nothing relevant
# (the model then answers from general knowledge instead of refusing). bge cosines
# run compressed-high; ~0.70 separates on-topic from off-topic.
RELEVANCE_THRESHOLD=0.70

# Set to a secret to open the /contribute ingestion endpoint (seed.sh uses it).
# Leave blank to keep contribution closed.
CONTRIBUTE_KEY=

# ── Voice input (OPT-IN) ──────────────────────────────────────────────────────
# Self-hosted speech-to-text (faster-whisper). To enable: set voice.enabled=true in
# 0gora.config.json AND activate the `voice` profile so the STT service runs:
COMPOSE_PROFILES=voice
# Whisper model size: tiny (~0.4GB RAM, fastest) | base (~1GB, balanced) | small (~2GB, best).
STT_MODEL=base
# STT_LANG: blank = auto-detect language; or pin e.g. en.
STT_LANG=
